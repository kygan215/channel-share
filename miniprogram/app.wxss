/* =========================================================== */
/* 全局设计变量                                                */
/* =========================================================== */

/* 微信品牌色 */
page {
  --primary: #07c160;
  --primary-dark: #06ad56;
  --primary-light: #ebf9f1;
  --primary-gradient: linear-gradient(135deg, #07c160, #06ad56);
  --danger: #e64340;
  --danger-light: #fef0f0;
  --blue: #1989fa;
  --blue-light: #ecf5ff;
  --orange: #ff976a;
  --orange-light: #fff7f0;
  --gray-1: #f7f8fa;
  --gray-2: #f2f3f5;
  --gray-3: #ebedf0;
  --gray-4: #dcdee0;
  --gray-5: #c8c9cc;
  --gray-6: #969799;
  --gray-7: #646566;
  --gray-8: #323233;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 999rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 26rpx;
  --font-lg: 28rpx;
  --font-xl: 30rpx;
  --font-2xl: 32rpx;
  --font-3xl: 36rpx;
  --font-4xl: 40rpx;
  background: var(--gray-1);
  box-sizing: border-box;
}

/* 移除 button 默认的边框伪元素 */
button::after {
  border: none;
}

/* 全局按钮重置 */
button {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: inherit;
  font-size: inherit;
}

/* 全局卡片样式 */
.card {
  background: #fff;
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: box-shadow 0.3s, transform 0.2s;
}

.card:active {
  box-shadow: var(--shadow-md);
}

/* 全局输入框 */
.input-field {
  width: 100%;
  height: 80rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: var(--font-lg);
  color: var(--gray-8);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s, background 0.2s;
}

.input-field:focus {
  background: #fff;
  border-color: var(--primary);
}

/* 全局标签 */
.tag {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  color: var(--gray-7);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
}

.tag.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}

.tag:active {
  opacity: 0.8;
}

/* 全局占位文字 */
.placeholder-text {
  color: var(--gray-5);
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

.slide-up {
  animation: slideUp 0.35s ease-out;
}

/* 滚动条隐藏 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* 页面切换过渡 */
page {
  animation: pageFadeIn 0.25s ease-out;
}

@keyframes pageFadeIn {
  from { opacity: 0.7; }
  to { opacity: 1; }
}
