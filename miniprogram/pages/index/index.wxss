/* =========================================================== */
/* 首页 - 品牌感设计                                            */
/* =========================================================== */

.page {
  padding: 0 0 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* =========================================================== */
/* 1. 顶部品牌区                                               */
/* =========================================================== */

.hero {
  position: relative;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 40%, #059e4e 100%);
  padding: 48rpx 32rpx 56rpx;
  overflow: hidden;
}

.hero-bg-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.hero-bg-pattern::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.hero-bg-pattern::after {
  content: '';
  position: absolute;
  bottom: -160rpx;
  left: -80rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.03);
}

.hero-content {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.hero-brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.95);
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.hero-text-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.hero-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  letter-spacing: 0.5rpx;
}

.hero-export-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: var(--radius-round);
  flex-shrink: 0;
  margin-top: 8rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
}
.hero-export-btn:active {
  background: rgba(255,255,255,0.35);
}
.hero-export-icon {
  font-size: 24rpx;
}
.hero-export-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}


/* =========================================================== */
/* 2. 数据概览栏                                               */
/* =========================================================== */

.stats-bar {
  display: flex;
  align-items: center;
  background: #fff;
  margin: -36rpx 28rpx 0;
  border-radius: 24rpx;
  padding: 28rpx 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.12);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--gray-8);
}

.stat-label {
  font-size: 20rpx;
  color: var(--gray-5);
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 52rpx;
  background: var(--gray-3);
}


/* =========================================================== */
/* 3. 功能菜单网格                                             */
/* =========================================================== */

.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  padding: 36rpx 28rpx 0;
}

.menu-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 44rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  animation: cardIn 0.5s ease-out both;
}

/* 卡片入场动画 */
.menu-card:nth-child(1) { animation-delay: 0.05s; }
.menu-card:nth-child(2) { animation-delay: 0.12s; }
.menu-card:nth-child(3) { animation-delay: 0.19s; }
.menu-card:nth-child(4) { animation-delay: 0.26s; }

@keyframes cardIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.menu-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 卡片顶部装饰条 */
.menu-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 70rpx;
  height: 6rpx;
  border-radius: 0 0 8rpx 8rpx;
}

.menu-card:nth-child(1)::before { background: var(--primary); }
.menu-card:nth-child(2)::before { background: #1989fa; }
.menu-card:nth-child(3)::before { background: #a855f7; }
.menu-card:nth-child(4)::before { background: #ff976a; }

.menu-card-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.icon-query {
  background: linear-gradient(135deg, #ebf9f1, #d4f5e3);
}
.icon-add {
  background: linear-gradient(135deg, #e8f5ff, #d0edff);
}
.icon-import {
  background: linear-gradient(135deg, #f3e8ff, #e8d5ff);
}
.icon-manage {
  background: linear-gradient(135deg, #fff3e0, #ffe8cc);
}

.menu-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--gray-8);
}

.menu-card-desc {
  font-size: 22rpx;
  color: var(--gray-5);
  text-align: center;
  line-height: 1.4;
}


/* =========================================================== */
/* 4. 隐私协议弹窗                                             */
/* =========================================================== */

.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.3s ease-out;
}

@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.privacy-dialog {
  width: 620rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: dialogSlideUp 0.35s ease-out;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

@keyframes dialogSlideUp {
  from { opacity: 0; transform: translateY(60rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.privacy-header {
  padding: 40rpx 36rpx 0;
  text-align: center;
}

.privacy-title {
  font-size: var(--font-3xl);
  font-weight: 700;
  color: var(--gray-8);
}

.privacy-body {
  flex: 1;
  padding: 28rpx 36rpx 0;
  overflow-y: auto;
}

.privacy-intro {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.privacy-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.privacy-item {
  font-size: var(--font-sm);
  color: var(--gray-7);
  line-height: 1.5;
  padding-left: 8rpx;
}

.privacy-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx 0;
  margin-bottom: 4rpx;
}

.privacy-link-text {
  font-size: var(--font-md);
  color: var(--primary);
  font-weight: 500;
}

.privacy-link-arrow {
  font-size: 32rpx;
  color: var(--primary);
  line-height: 1;
}

.hover-opacity {
  opacity: 0.7;
}

.privacy-footer {
  padding: 24rpx 36rpx 40rpx;
  border-top: 2rpx solid var(--gray-2);
}

.privacy-checkbox {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0 20rpx;
}

.checkbox-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--gray-4);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.checkbox-checked {
  background: var(--primary);
  border-color: var(--primary);
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.4;
}

.checkbox-highlight {
  color: var(--primary);
  font-weight: 500;
}

.privacy-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-xl);
  font-weight: 600;
  color: #fff;
  background: var(--gray-3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s;
}

.privacy-btn-active {
  background: var(--primary-gradient);
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.35);
}

.privacy-btn-active:active {
  opacity: 0.9;
  transform: scale(0.97);
}


/* =========================================================== */
/* 5. 权限验证门（访问受限）                                    */
/* =========================================================== */

.auth-gate {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--gray-1);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.3s ease-out;
}

.auth-gate-card {
  width: 560rpx;
  background: #fff;
  border-radius: var(--radius-xl);
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  animation: dialogSlideUp 0.35s ease-out;
}

.auth-gate-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.auth-gate-title {
  font-size: var(--font-4xl);
  font-weight: 700;
  color: var(--gray-8);
  margin-bottom: 16rpx;
}

.auth-gate-desc {
  font-size: var(--font-lg);
  color: var(--gray-7);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.auth-gate-hint {
  font-size: var(--font-md);
  color: var(--gray-6);
  text-align: center;
  line-height: 1.5;
}

.auth-gate-divider {
  width: 100%;
  height: 2rpx;
  background: var(--gray-3);
  margin: 32rpx 0 24rpx;
}

.auth-gate-contact {
  width: 100%;
}

.auth-gate-contact-label {
  font-size: var(--font-sm);
  color: var(--gray-6);
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.auth-gate-contact-step {
  font-size: var(--font-sm);
  color: var(--gray-6);
  display: block;
  line-height: 1.8;
  padding-left: 8rpx;
}
