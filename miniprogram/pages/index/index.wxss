/* =========================================================== */
/* 首页 - 全新品牌化设计                                        */
/* =========================================================== */

.page {
  padding: 0;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--gray-1);
}

/* =========================================================== */
/* 1. 顶部品牌区                                                */
/* =========================================================== */

.hero {
  position: relative;
  padding: 56rpx 32rpx 0;
  overflow: hidden;
  min-height: 280rpx;
}

/* 背景图片铺满 */
.hero-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

/* 半透明暗色遮罩，让文字更清晰 */
.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.35);
  pointer-events: none;
}

/* 背景大 Logo 水印 */
.hero-bg-logo {
  display: none;
}

.hero-content {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
  z-index: 1;
  padding-bottom: 60rpx;
}

.hero-brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-text-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1.1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}

.hero-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.hero-export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-round);
  flex-shrink: 0;
  margin-top: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
}

.hero-export-btn:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.95);
}

.hero-export-icon {
  font-size: 24rpx;
}

.hero-export-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

/* =========================================================== */
/* 2. 数据概览 — 4个彩色统计卡片                                 */
/* =========================================================== */

.stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-top: 20rpx;
  position: relative;
  z-index: 3;
}

.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
  overflow: hidden;
  position: relative;
}

.stat-card:active {
  transform: scale(0.96);
}

/* 左侧彩色装饰条 */
.stat-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 0 4rpx 4rpx 0;
}

.stat-card-total::before { background: #07c160; }
.stat-card-hired::before { background: #1989fa; }
.stat-card-quality::before { background: #ff976a; }
.stat-card-provinces::before { background: #a855f7; }
.stat-card-age::before { background: #e74c3c; }

.stat-card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
  z-index: 1;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--gray-8);
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--gray-5);
  font-weight: 500;
}

/* =========================================================== */
/* 3. 分区标题                                                  */
/* =========================================================== */

.section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 36rpx 28rpx 16rpx;
}

.section-label-icon {
  font-size: 28rpx;
}

.section-label-text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--gray-8);
  letter-spacing: 1rpx;
}

/* =========================================================== */
/* 4. 快捷操作 — 功能卡片                                       */
/* =========================================================== */

.action-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-2);
  transition: all 0.2s;
  min-height: 100rpx;
}

.action-card:active {
  transform: scale(0.96);
  border-color: var(--primary-light);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.action-card-query .action-icon-wrap {
  background: linear-gradient(135deg, #ebf9f1, #d4f5e3);
}
.action-card-add .action-icon-wrap {
  background: linear-gradient(135deg, #e8f5ff, #d0edff);
}
.action-card-import .action-icon-wrap {
  background: linear-gradient(135deg, #f3e8ff, #e8d5ff);
}
.action-card-manage .action-icon-wrap {
  background: linear-gradient(135deg, #fff3e0, #ffe8cc);
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.action-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-8);
}

.action-desc {
  font-size: 20rpx;
  color: var(--gray-5);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-arrow {
  font-size: 32rpx;
  color: var(--gray-4);
  flex-shrink: 0;
}

/* =========================================================== */
/* 5. 隐私协议弹窗                                              */
/* =========================================================== */

.privacy-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.3s ease-out;
}

@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.privacy-dialog {
  width: 620rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: dialogSlideUp 0.35s ease-out;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

@keyframes dialogSlideUp {
  from { opacity: 0; transform: translateY(60rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.privacy-header {
  padding: 40rpx 36rpx 0;
  text-align: center;
}

.privacy-title {
  font-size: var(--font-3xl);
  font-weight: 700;
  color: var(--gray-8);
}

.privacy-body {
  flex: 1;
  padding: 28rpx 36rpx 0;
  overflow-y: auto;
}

.privacy-intro {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.privacy-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.privacy-item {
  font-size: var(--font-sm);
  color: var(--gray-7);
  line-height: 1.5;
  padding-left: 8rpx;
}

.privacy-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx 0;
  margin-bottom: 4rpx;
}

.privacy-link-text {
  font-size: var(--font-md);
  color: var(--primary);
  font-weight: 500;
}

.privacy-link-arrow {
  font-size: 32rpx;
  color: var(--primary);
  line-height: 1;
}

.hover-opacity {
  opacity: 0.7;
}

.privacy-footer {
  padding: 24rpx 36rpx 40rpx;
  border-top: 2rpx solid var(--gray-2);
}

.privacy-checkbox {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0 20rpx;
}

.checkbox-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--gray-4);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.checkbox-checked {
  background: var(--primary);
  border-color: var(--primary);
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.4;
}

.checkbox-highlight {
  color: var(--primary);
  font-weight: 500;
}

.privacy-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-round);
  font-size: var(--font-xl);
  font-weight: 600;
  color: #fff;
  background: var(--gray-3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s;
}

.privacy-btn-active {
  background: var(--primary-gradient);
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.35);
}

.privacy-btn-active:active {
  opacity: 0.9;
  transform: scale(0.97);
}

/* =========================================================== */
/* 6. 权限验证门                                                */
/* =========================================================== */

.auth-gate {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--gray-1);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.3s ease-out;
}

.auth-gate-card {
  width: 560rpx;
  background: #fff;
  border-radius: var(--radius-xl);
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  animation: dialogSlideUp 0.35s ease-out;
}

.auth-gate-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.auth-gate-title {
  font-size: var(--font-4xl);
  font-weight: 700;
  color: var(--gray-8);
  margin-bottom: 16rpx;
}

.auth-gate-desc {
  font-size: var(--font-lg);
  color: var(--gray-7);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.auth-gate-hint {
  font-size: var(--font-md);
  color: var(--gray-6);
  text-align: center;
  line-height: 1.5;
}

.auth-gate-divider {
  width: 100%;
  height: 2rpx;
  background: var(--gray-3);
  margin: 32rpx 0 24rpx;
}

.auth-gate-contact {
  width: 100%;
}

.auth-gate-contact-label {
  font-size: var(--font-sm);
  color: var(--gray-6);
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.auth-gate-contact-step {
  font-size: var(--font-sm);
  color: var(--gray-6);
  display: block;
  line-height: 1.8;
  padding-left: 8rpx;
}
