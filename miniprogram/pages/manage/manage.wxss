/* ============================================================
   管理页样式 — 卡片样式继承 query-results + 管理特有扩展
   ============================================================ */

@import '../query-results/query-results.wxss';

/* =========================================================== */
/* 顶部工具栏（品牌风格）                                       */
/* =========================================================== */

.toolbar {
  padding: 24rpx 20rpx 16rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 40%, #059e4e 100%);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  position: relative;
  overflow: hidden;
}

.toolbar::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -60rpx;
  width: 350rpx;
  height: 350rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.toolbar::after {
  content: '';
  position: absolute;
  bottom: -140rpx;
  left: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
}

.toolbar-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  position: relative;
  z-index: 1;
  padding-left: 4rpx;
  letter-spacing: 1rpx;
}

.toolbar-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  position: relative;
  z-index: 1;
  padding-left: 4rpx;
}

.search-row {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-round);
  padding: 0 12rpx 0 20rpx;
  gap: 8rpx;
  transition: all 0.2s;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

.search-row:focus-within {
  background: rgba(255, 255, 255, 0.95);
  border-color: #fff;
}

.search-row:focus-within .search-icon { color: var(--primary); }
.search-row:focus-within .search-input { color: var(--gray-8); }
.search-row:focus-within .search-ph { color: var(--gray-5); }

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  color: rgba(255, 255, 255, 0.8);
}

.search-input {
  flex: 1;
  font-size: var(--font-md);
  color: #fff;
  height: 100%;
}

.search-ph {
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.search-clear {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  padding: 8rpx 12rpx;
}

.toolbar-btns {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.btn-add {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}

.btn-add:active {
  background: rgba(255, 255, 255, 0.4);
  transform: scale(0.97);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-batch {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  font-weight: 500;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.btn-batch.active {
  background: rgba(230, 67, 64, 0.8);
  border-color: transparent;
}

/* =========================================================== */
/* 筛选区域（卡片式）                                          */
/* =========================================================== */

.filter-section {
  padding: 16rpx 20rpx 20rpx;
  background: var(--gray-1);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.filter-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20rpx 20rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-2);
}

.filter-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.filter-card-icon {
  font-size: 26rpx;
}

.filter-card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--gray-8);
  flex: 1;
}

.filter-card-selected {
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-col {
  flex: 1;
  min-width: 0;
}

.tag-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding: 4rpx 0;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  height: 54rpx;
  padding: 0 24rpx;
  margin-right: 10rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  color: var(--gray-7);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
  font-weight: 500;
}

.filter-tag:active {
  transform: scale(0.94);
}

.filter-tag.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(7, 193, 96, 0.25);
}

.filter-search-input {
  width: 100%;
  height: 58rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  box-sizing: border-box;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.filter-search-input:focus {
  background: #fff;
  border-color: var(--primary);
}

/* =========================================================== */
/* 编辑/删除按钮                                               */
/* =========================================================== */

.btn-edit {
  background: var(--primary-light);
  color: var(--primary);
}

.btn-delete {
  background: var(--danger-light);
  color: var(--danger);
}

/* =========================================================== */
/* 批量删除                                                    */
/* =========================================================== */

.btn-batch {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  background: var(--gray-2);
  color: var(--gray-7);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  font-weight: 500;
}

.btn-batch.active {
  background: var(--danger-light);
  color: var(--danger);
}

.batch-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-bottom: 2rpx solid var(--gray-2);
  gap: 12rpx;
  flex-shrink: 0;
}

.batch-select-all {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: var(--gray-2);
  color: var(--gray-7);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  flex-shrink: 0;
}

.batch-count {
  flex: 1;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--danger);
  text-align: center;
}

.batch-delete-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: var(--danger);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  font-weight: 600;
  flex-shrink: 0;
}

.batch-delete-btn:active {
  opacity: 0.8;
}

.card-checkbox {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
  border-radius: 50%;
  background: var(--gray-1);
  transition: all 0.15s;
}

.card-checkbox.checked {
  color: var(--danger);
  background: #fef0f0;
}

/* =========================================================== */
/* 健康证区域（覆盖导入样式，局部调整）                        */
/* =========================================================== */

.healthcert-section {
  margin-top: 12rpx;
}
  font-weight: 600;
  color: var(--gray-7);
}

.healthcert-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.healthcert-btn {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-round);
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
  transition: opacity 0.2s;
}

.healthcert-btn:active {
  opacity: 0.7;
}

.healthcert-btn.btn-upload {
  background: var(--blue-light);
  color: var(--blue);
}

.healthcert-btn.btn-view {
  background: var(--gray-2);
  color: var(--gray-7);
}

.healthcert-btn.btn-review {
  background: var(--primary-light);
  color: var(--primary);
}

/* =========================================================== */
/* 审核弹窗                                                    */
/* =========================================================== */

.review-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.review-modal {
  width: 640rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 16rpx;
}

.review-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
}

.review-close {
  font-size: 36rpx;
  color: var(--gray-5);
  padding: 8rpx;
  flex-shrink: 0;
}

.review-close:active {
  color: var(--gray-7);
}

.review-body {
  padding: 0 28rpx 28rpx;
  overflow-y: auto;
}

.review-name {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--gray-8);
  margin-bottom: 16rpx;
}

.review-image {
  width: 100%;
  border-radius: var(--radius-md);
  background: var(--gray-2);
  margin-bottom: 20rpx;
}

.review-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.review-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 600;
  transition: opacity 0.2s;
}

.review-btn:active {
  opacity: 0.8;
}

.review-btn.btn-approve {
  background: var(--primary-gradient);
  color: #fff;
}

.review-btn.btn-reject {
  background: var(--danger-light);
  color: var(--danger);
}

.review-reject-row {
  margin-top: 4rpx;
}

.review-reject-input {
  width: 100%;
  height: 64rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  box-sizing: border-box;
}

/* =========================================================== */
/* 手机号白名单验证遮罩                                        */
/* =========================================================== */

.phone-auth-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.phone-auth-box {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.phone-auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gray-8);
  margin-bottom: 12rpx;
}

.phone-auth-desc {
  font-size: 26rpx;
  color: var(--gray-5);
  margin-bottom: 36rpx;
  text-align: center;
}

.phone-auth-input {
  width: 100%;
  height: 80rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--gray-8);
  text-align: center;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.phone-auth-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
}

.phone-auth-btn:active {
  opacity: 0.8;
}
