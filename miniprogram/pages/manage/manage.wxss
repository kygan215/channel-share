/* ============================================================
   管理页样式 — 卡片样式继承 query-results + 管理特有扩展
   ============================================================ */

@import '../query-results/query-results.wxss';

/* =========================================================== */
/* 顶部工具栏（品牌风格）                                       */
/* =========================================================== */

.toolbar {
  padding: 24rpx 20rpx 16rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 40%, #059e4e 100%);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  position: relative;
  overflow: hidden;
}

.toolbar::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -60rpx;
  width: 350rpx;
  height: 350rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.toolbar::after {
  content: '';
  position: absolute;
  bottom: -140rpx;
  left: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
}

.toolbar-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  position: relative;
  z-index: 1;
  padding-left: 4rpx;
  letter-spacing: 1rpx;
}

.toolbar-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  position: relative;
  z-index: 1;
  padding-left: 4rpx;
}

.search-row {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-round);
  padding: 0 12rpx 0 20rpx;
  gap: 8rpx;
  transition: all 0.2s;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

.search-row:focus-within {
  background: rgba(255, 255, 255, 0.95);
  border-color: #fff;
}

.search-row:focus-within .search-icon { color: var(--primary); }
.search-row:focus-within .search-input { color: var(--gray-8); }
.search-row:focus-within .search-ph { color: var(--gray-5); }

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  color: rgba(255, 255, 255, 0.8);
}

.search-input {
  flex: 1;
  font-size: var(--font-md);
  color: #fff;
  height: 100%;
}

.search-ph {
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.search-clear {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  padding: 8rpx 12rpx;
}

.toolbar-btns {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.btn-add {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}

.btn-add:active {
  background: rgba(255, 255, 255, 0.4);
  transform: scale(0.97);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-batch {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  font-weight: 500;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.btn-batch.active {
  background: rgba(230, 67, 64, 0.8);
  border-color: transparent;
}

/* =========================================================== */
/* 筛选区域（卡片式）                                          */
/* =========================================================== */

.filter-section {
  padding: 16rpx 0 20rpx;
  background: var(--gray-1);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.filter-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20rpx 20rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-2);
}

.filter-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.filter-card-icon {
  font-size: 26rpx;
}

.filter-card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--gray-8);
  flex: 1;
}

.filter-card-selected {
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-col {
  flex: 1;
  min-width: 0;
}

.tag-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding: 4rpx 0;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  height: 54rpx;
  padding: 0 24rpx;
  margin-right: 10rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  color: var(--gray-7);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
  font-weight: 500;
}

.filter-tag:active {
  transform: scale(0.94);
}

.filter-tag.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(7, 193, 96, 0.25);
}

.filter-search-input {
  width: 100%;
  height: 58rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  box-sizing: border-box;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.filter-search-input:focus {
  background: #fff;
  border-color: var(--primary);
}

/* =========================================================== */
/* 编辑/删除按钮                                               */
/* =========================================================== */

.btn-edit {
  background: var(--primary-light);
  color: var(--primary);
}

.btn-delete {
  background: var(--danger-light);
  color: var(--danger);
}

/* =========================================================== */
/* 批量删除                                                    */
/* =========================================================== */

.btn-batch {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  background: var(--gray-2);
  color: var(--gray-7);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  font-weight: 500;
}

.btn-batch.active {
  background: var(--danger-light);
  color: var(--danger);
}

.batch-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff;
  border-bottom: 2rpx solid var(--gray-2);
  gap: 12rpx;
  flex-shrink: 0;
}

.batch-select-all {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: var(--gray-2);
  color: var(--gray-7);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  flex-shrink: 0;
}

.batch-count {
  flex: 1;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--danger);
  text-align: center;
}

.batch-delete-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: var(--danger);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  font-weight: 600;
  flex-shrink: 0;
}

.batch-delete-btn:active {
  opacity: 0.8;
}

.card-checkbox {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
  border-radius: 50%;
  background: var(--gray-1);
  transition: all 0.15s;
}

.card-checkbox.checked {
  color: var(--danger);
  background: #fef0f0;
}

/* =========================================================== */
/* 健康证区域（覆盖导入样式，局部调整）                        */
/* =========================================================== */

.healthcert-section {
  margin-top: 12rpx;
}

.healthcert-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.healthcert-btn {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-round);
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
  transition: opacity 0.2s;
}

.healthcert-btn:active {
  opacity: 0.7;
}

.healthcert-btn.btn-upload {
  background: var(--blue-light);
  color: var(--blue);
}

.healthcert-btn.btn-view {
  background: var(--gray-2);
  color: var(--gray-7);
}

.healthcert-btn.btn-review {
  background: var(--primary-light);
  color: var(--primary);
}

/* =========================================================== */
/* 审核弹窗                                                    */
/* =========================================================== */

.review-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.review-modal {
  width: 640rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 16rpx;
}

.review-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
}

.review-close {
  font-size: 36rpx;
  color: var(--gray-5);
  padding: 8rpx;
  flex-shrink: 0;
}

.review-close:active {
  color: var(--gray-7);
}

.review-body {
  padding: 0 28rpx 28rpx;
  overflow-y: auto;
}

.review-name {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--gray-8);
  margin-bottom: 16rpx;
}

.review-image {
  width: 100%;
  border-radius: var(--radius-md);
  background: var(--gray-2);
  margin-bottom: 20rpx;
}

.review-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.review-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 600;
  transition: opacity 0.2s;
}

.review-btn:active {
  opacity: 0.8;
}

.review-btn.btn-approve {
  background: var(--primary-gradient);
  color: #fff;
}

.review-btn.btn-reject {
  background: var(--danger-light);
  color: var(--danger);
}

.review-reject-row {
  margin-top: 4rpx;
}

.review-reject-input {
  width: 100%;
  height: 64rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  box-sizing: border-box;
}

/* =========================================================== */
/* 聘用弹窗（选择时间区段）                                     */
/* =========================================================== */

.hire-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.3s ease-out;
}

.hire-modal {
  width: 620rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.hire-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx 16rpx;
}

.hire-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
}

.hire-close {
  font-size: 36rpx;
  color: var(--gray-5);
  padding: 8rpx;
  flex-shrink: 0;
}

.hire-close:active {
  color: var(--gray-7);
}

.hire-body {
  padding: 0 28rpx 32rpx;
}

.hire-name {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--gray-8);
  margin-bottom: 8rpx;
}

.hire-desc {
  font-size: var(--font-md);
  color: var(--gray-6);
  margin-bottom: 28rpx;
  display: block;
}

.hire-date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.hire-date-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hire-date-label {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-6);
}

.hire-date-value {
  height: 72rpx;
  line-height: 72rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-lg);
  color: var(--gray-8);
  text-align: center;
  font-weight: 600;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.hire-date-value:active {
  border-color: var(--primary);
  background: #fff;
}

.hire-date-arrow {
  font-size: 36rpx;
  color: var(--gray-5);
  margin-top: 36rpx;
  flex-shrink: 0;
}

.hire-tips {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: var(--primary-light);
  border-radius: var(--radius-md);
  margin-bottom: 28rpx;
}

.hire-tip-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.hire-tip-text {
  font-size: var(--font-sm);
  color: var(--primary);
  line-height: 1.5;
}

.hire-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hire-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 600;
}

.hire-btn:active {
  opacity: 0.8;
}

.btn-hire-confirm {
  background: var(--primary-gradient);
  color: #fff;
}

.btn-hire-cancel {
  background: var(--gray-2);
  color: var(--gray-7);
}

/* =========================================================== */
/* 聘用期显示                                                   */
/* =========================================================== */

.hire-period-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 0;
  margin-top: 4rpx;
}

.hire-period-text {
  font-size: var(--font-sm);
  color: #3b7cff;
  font-weight: 500;
  background: #e8f4fd;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* =========================================================== */
/* 解聘弹窗                                                     */
/* =========================================================== */

.unhire-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.3s ease-out;
}

.unhire-desc {
  font-size: var(--font-md);
  color: var(--gray-7);
  margin-bottom: 12rpx;
  display: block;
}

.unhire-textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  box-sizing: border-box;
  line-height: 1.5;
}

/* =========================================================== */
/* 个人模式提示条                                               */
/* =========================================================== */

.scope-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #fff7e6, #fff3d6);
  border-bottom: 2rpx solid #ffe0a0;
  gap: 6rpx;
  flex-wrap: wrap;
}

.scope-hint-icon {
  font-size: 24rpx;
}

.scope-hint-text {
  font-size: var(--font-sm);
  color: #b8860b;
  font-weight: 500;
}

.scope-hint-link {
  font-size: var(--font-sm);
  color: #3b7cff;
  font-weight: 600;
  text-decoration: underline;
  padding: 4rpx 0;
}

.scope-hint-link:active {
  opacity: 0.7;
}

/* =========================================================== */
/* 年龄范围筛选                                                 */
/* =========================================================== */

.age-range-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.age-input {
  flex: 1;
  height: 64rpx;
  background: var(--gray-2);
  border-radius: var(--radius-sm);
  padding: 0 16rpx;
  font-size: 28rpx;
  color: var(--gray-8);
  text-align: center;
  min-width: 0;
}

.age-separator {
  font-size: 28rpx;
  color: var(--gray-5);
  font-weight: 700;
}

/* =========================================================== */
/* 搜索结果计数                                                 */
/* =========================================================== */

.filter-result-info {
  padding: 12rpx 0 0;
  text-align: center;
}

.filter-result-text {
  font-size: 26rpx;
  color: var(--gray-5);
}

.filter-result-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

/* =========================================================== */
/* 搜索按钮                                                     */
/* =========================================================== */

.filter-search-btn-wrap {
  padding: 16rpx 0;
}

.filter-search-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 2rpx;
}

.filter-search-btn:active,
.search-btn-hover {
  opacity: 0.85;
  transform: scale(0.96);
}

/* =========================================================== */
/* 回到顶部按钮                                                 */
/* =========================================================== */

.back-to-top {
  position: fixed;
  right: 32rpx;
  bottom: 80rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 40rpx;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 999;
  opacity: 0;
  transform: translateY(40rpx);
  transition: all 0.25s ease-out;
  pointer-events: none;
}

.back-to-top.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.back-to-top-hover {
  opacity: 0.8;
  transform: scale(0.9);
}
