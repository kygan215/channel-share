<view class="page">

  <!-- ==================== 记录管理权限 ==================== -->
  <view class="section slide-up">
    <view class="section-header">
      <text class="section-title">📋 记录管理权限</text>
      <text class="section-desc">控制各功能在首页和管理页的可见性</text>
    </view>

    <view class="toggle-item" data-field="add" bindtap="togglePerm">
      <view class="toggle-info">
        <text class="toggle-icon">➕</text>
        <view class="toggle-text">
          <text class="toggle-label">新增记录</text>
          <text class="toggle-desc">允许在首页显示"新增"按钮</text>
        </view>
      </view>
      <switch checked="{{permAdd}}" disabled />
    </view>

    <view class="toggle-item" data-field="edit" bindtap="togglePerm">
      <view class="toggle-info">
        <text class="toggle-icon">✏️</text>
        <view class="toggle-text">
          <text class="toggle-label">修改记录</text>
          <text class="toggle-desc">允许创建者编辑自己的记录</text>
        </view>
      </view>
      <switch checked="{{permEdit}}" disabled />
    </view>

    <view class="toggle-item" data-field="delete" bindtap="togglePerm">
      <view class="toggle-info">
        <text class="toggle-icon">🗑️</text>
        <view class="toggle-text">
          <text class="toggle-label">删除记录</text>
          <text class="toggle-desc">允许创建者删除自己的记录</text>
        </view>
      </view>
      <switch checked="{{permDelete}}" disabled />
    </view>

    <view class="toggle-item" data-field="promoter" bindtap="togglePerm">
      <view class="toggle-info">
        <text class="toggle-icon">👤</text>
        <view class="toggle-text">
          <text class="toggle-label">促销员管理</text>
          <text class="toggle-desc">允许在管理页进行聘用/解聘操作</text>
        </view>
      </view>
      <switch checked="{{permPromoter}}" disabled />
    </view>

    <view class="toggle-item" data-field="review" bindtap="togglePerm">
      <view class="toggle-info">
        <text class="toggle-icon">✅</text>
        <view class="toggle-text">
          <text class="toggle-label">健康证审核</text>
          <text class="toggle-desc">允许审核上传的健康证图片</text>
        </view>
      </view>
      <switch checked="{{permReview}}" disabled />
    </view>
  </view>

  <!-- ==================== 手机号验证 ==================== -->
  <view class="section slide-up">
    <view class="section-header">
      <text class="section-title">📱 手机号</text>
      <text class="section-desc">设置你的手机号用于白名单验证</text>
    </view>
    <view class="info-item">
      <text class="info-label">手机号</text>
      <input class="info-input" placeholder="输入手机号" value="{{phone}}" bindinput="onPhoneInput" type="number" maxlength="11" />
      <button class="info-btn" bindtap="confirmPhone">确认</button>
    </view>
  </view>

  <!-- ==================== 管理员设置 ==================== -->
  <view class="section slide-up">
    <view class="section-header">
      <text class="section-title">🔐 管理员设置</text>
      <text class="section-desc">云函数权限白名单管理</text>
    </view>

    <view class="info-item">
      <text class="info-label">我的角色</text>
      <text class="info-value {{isAdmin ? 'admin-role' : ''}}">{{isAdmin ? '👑 管理员' : '👤 普通用户'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">我的 OPENID</text>
      <view class="info-value-row">
        <text class="openid-text">{{myOpenid}}</text>
        <button class="mini-btn" bindtap="copyOpenid">复制</button>
      </view>
    </view>

    <view wx:if="{{isAdmin}}" class="admin-mgmt">
      <view class="info-item" bindtap="toggleAddAdmin">
        <text class="info-label">{{showAddAdmin ? '✕ 取消' : '＋ 添加管理员'}}</text>
      </view>

      <view wx:if="{{showAddAdmin}}" class="add-admin-row">
        <input class="info-input add-input" placeholder="输入对方的 OPENID" value="{{addOpenid}}" bindinput="onAddOpenidInput" />
        <button class="mini-btn primary-btn" bindtap="confirmAddAdmin">确认</button>
      </view>

      <view wx:for="{{users}}" wx:key="openid" class="user-item">
        <view class="user-info">
          <text class="user-openid">🔑 {{item.openid}}</text>
          <text class="user-meta">角色：{{item.role}} ｜ {{item._createdAt ? '创建于 ' + item._createdAt : ''}}</text>
        </view>
        <button wx:if="{{item.openid !== myOpenid}}" class="mini-btn danger-btn" data-openid="{{item.openid}}" bindtap="removeAdmin">移除</button>
      </view>
    </view>
  </view>

  <!-- ==================== 手机号白名单 ==================== -->
  <view wx:if="{{isAdmin}}" class="section slide-up">
    <view class="section-header">
      <text class="section-title">📞 手机号白名单</text>
      <text class="section-desc">只有白名单中的手机号才能查看数据（共 {{whitelist.length}} 人）</text>
    </view>

    <view class="info-item" bindtap="toggleAddWhitelist">
      <text class="info-label">{{showAddWhitelist ? '✕ 取消' : '＋ 批量添加白名单'}}</text>
    </view>

    <view wx:if="{{showAddWhitelist}}" class="whitelist-add-section">
      <textarea class="whitelist-textarea" placeholder="输入手机号，每行一个，或逗号/空格分隔&#10;例如：&#10;13800138000&#10;13900139000" value="{{whitelistBatchText}}" bindinput="onWhitelistBatchInput" />
      <button class="mini-btn primary-btn full-btn" bindtap="confirmAddWhitelist">批量添加</button>
    </view>

    <view wx:for="{{whitelist}}" wx:key="phone" class="user-item">
      <view class="user-info">
        <text class="user-openid">📱 {{item.phone}}</text>
        <text class="user-meta">{{item._createdAt ? '添加于 ' + item._createdAt : ''}}</text>
      </view>
      <button class="mini-btn danger-btn" data-phone="{{item.phone}}" bindtap="removeWhitelist">移除</button>
    </view>

    <view wx:if="{{whitelist.length === 0}}" class="empty-tip">暂无白名单，批量添加后团队成员即可查看数据</view>
  </view>

  <!-- ==================== 系统信息 ==================== -->
  <view class="section slide-up">
    <view class="section-header">
      <text class="section-title">ℹ️ 系统信息</text>
    </view>
    <view class="info-item">
      <text class="info-label">当前版本</text>
      <text class="info-value">v1.0.0</text>
    </view>
  </view>
</view>
