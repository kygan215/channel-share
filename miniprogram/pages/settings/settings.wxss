/* =========================================================== */
/* 设置页面样式                                                */
/* =========================================================== */

.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ---- 分区 ---- */
.section {
  background: #fff;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.section-header {
  padding: 28rpx 24rpx 8rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-8);
}

.section-desc {
  display: block;
  font-size: var(--font-xs);
  color: var(--gray-5);
  margin-top: 4rpx;
}

/* ---- 开关项 ---- */
.toggle-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-bottom: 2rpx solid var(--gray-2);
}

.toggle-item:last-child {
  border-bottom: none;
}

.toggle-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.toggle-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.toggle-text {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.toggle-label {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--gray-8);
}

.toggle-desc {
  font-size: 20rpx;
  color: var(--gray-5);
}

/* ---- 菜单项 ---- */
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid var(--gray-2);
  gap: 16rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--gray-1);
}

.menu-item-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.menu-item-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.menu-item-label {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--gray-8);
}

.menu-item-desc {
  font-size: 20rpx;
  color: var(--gray-5);
}

.menu-item-arrow {
  font-size: 36rpx;
  color: var(--gray-5);
  flex-shrink: 0;
}

.menu-item-value {
  font-size: var(--font-md);
  color: var(--gray-5);
}

/* ---- 信息项（手机号） ---- */
.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-bottom: 2rpx solid var(--gray-2);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-lg);
  color: var(--gray-7);
  flex-shrink: 0;
}

.info-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-value {
  font-size: var(--font-lg);
  color: var(--gray-8);
  font-weight: 500;
}

.info-value.empty {
  color: var(--gray-5);
  font-weight: 400;
}

.info-btn {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-round);
  font-size: 22rpx;
  font-weight: 500;
}

.info-btn:active {
  opacity: 0.7;
}

.info-input {
  height: 64rpx;
  width: 240rpx;
  background: var(--gray-2);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: var(--font-lg);
  color: var(--gray-8);
  text-align: right;
  box-sizing: border-box;
}

/* ---- 管理员设置 ---- */
.admin-role {
  color: #07c160;
  font-weight: 700;
}

.admin-mgmt {
  border-top: 2rpx solid var(--gray-2);
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
}

.openid-text {
  font-size: 20rpx;
  color: var(--gray-5);
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-btn {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-round);
  font-size: 22rpx;
  font-weight: 500;
  border: none;
  flex-shrink: 0;
}

.mini-btn:active {
  opacity: 0.7;
}

.primary-btn {
  background: var(--primary);
  color: #fff;
}

.danger-btn {
  background: #fff1f0;
  color: #ff4d4f;
}

.add-admin-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
}

.add-input {
  width: auto;
  flex: 1;
  text-align: left;
}

.user-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-top: 2rpx solid var(--gray-2);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.user-openid {
  font-size: 20rpx;
  color: var(--gray-7);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-meta {
  font-size: 18rpx;
  color: var(--gray-5);
}

/* ---- 白名单 ---- */
.whitelist-add-section {
  padding: 16rpx 24rpx;
  border-top: 2rpx solid var(--gray-2);
}

.whitelist-textarea {
  width: 100%;
  height: 160rpx;
  background: var(--gray-2);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: var(--gray-8);
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.full-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 600;
}

.empty-tip {
  padding: 32rpx 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--gray-5);
}
