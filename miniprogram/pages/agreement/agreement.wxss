.page {
  padding: 32rpx 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.agreement-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.agreement-title {
  font-size: var(--font-3xl);
  font-weight: 800;
  color: var(--gray-8);
  margin-bottom: 8rpx;
  display: block;
  text-align: center;
}

.agreement-update {
  font-size: 20rpx;
  color: var(--gray-5);
  margin-bottom: 32rpx;
  display: block;
  text-align: center;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-8);
  margin-bottom: 12rpx;
  display: block;
}

.section-text {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.7;
  display: block;
}

.bullet-list {
  padding-left: 20rpx;
}

.bullet-item {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.7;
  margin-bottom: 6rpx;
  display: list-item;
  list-style: disc;
  margin-left: 20rpx;
}

.back-btn-wrapper {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  font-size: var(--font-xl);
  font-weight: 600;
  border-radius: var(--radius-md);
  transition: opacity 0.2s;
}

.back-btn:active {
  opacity: 0.8;
}
