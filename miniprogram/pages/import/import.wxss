/* =========================================================== */
/* 导入页样式                                                   */
/* =========================================================== */

.page {
  padding: 0 0 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  padding: 0 24rpx;
}

/* =========================================================== */
/* 1. 步骤指示器                                               */
/* =========================================================== */

.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  gap: 0;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--gray-3);
  color: var(--gray-6);
  font-size: var(--font-sm);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.step.active .step-circle {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(7, 193, 96, 0.3);
}

.step.done .step-circle {
  background: var(--primary);
  color: #fff;
}

.step-label {
  font-size: 20rpx;
  color: var(--gray-6);
  font-weight: 500;
}

.step.active .step-label {
  color: var(--primary);
  font-weight: 600;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: var(--gray-3);
  margin: 0 8rpx;
  margin-bottom: 40rpx;
  border-radius: 4rpx;
  transition: background 0.3s;
}

.step-line.done {
  background: var(--primary);
}

/* =========================================================== */
/* 2. 上传区域                                                 */
/* =========================================================== */

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  border: 4rpx dashed var(--gray-4);
  margin-bottom: 24rpx;
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s;
}

.import-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.import-card .upload-area {
  margin-bottom: 18rpx;
}

.upload-area:active {
  border-color: var(--primary);
  background: var(--primary-light);
  transform: scale(0.98);
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.upload-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
}

.upload-desc {
  font-size: var(--font-sm);
  color: var(--gray-5);
}

.template-download-btn {
  height: 76rpx;
  line-height: 76rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

.template-download-tip {
  display: block;
  margin-top: 14rpx;
  color: var(--gray-6);
  font-size: var(--font-sm);
  line-height: 1.5;
  text-align: center;
}

/* =========================================================== */
/* 3. 格式提示卡                                               */
/* =========================================================== */

.tip-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.tip-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-8);
  margin-bottom: 16rpx;
  display: block;
}

.tip-item {
  font-size: var(--font-md);
  color: var(--gray-6);
  line-height: 1.8;
}

.tip-code {
  display: inline;
  background: var(--primary-light);
  color: var(--primary);
  padding: 0 8rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tip-divider {
  height: 2rpx;
  background: var(--gray-3);
  margin: 20rpx 0;
}

.tip-item-right {
  font-size: var(--font-sm);
  color: var(--blue);
  line-height: 1.8;
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: var(--blue-light);
  border-radius: var(--radius-sm);
}

.example-table {
  display: flex;
  flex-direction: column;
  border: 2rpx solid var(--gray-3);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-top: 12rpx;
}

.example-row {
  display: flex;
  border-bottom: 2rpx solid var(--gray-3);
}

.example-row:last-child {
  border-bottom: none;
}

.example-header {
  background: var(--gray-2);
  font-weight: 600;
}

.example-cell {
  flex: 1;
  padding: 12rpx 16rpx;
  font-size: 20rpx;
  color: var(--gray-7);
  border-right: 2rpx solid var(--gray-3);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.example-cell:last-child {
  border-right: none;
}

.example-header .example-cell {
  color: var(--gray-7);
  font-weight: 600;
}

/* =========================================================== */
/* 4. 文件信息                                                 */
/* =========================================================== */

.file-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.file-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--gray-8);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-count {
  font-size: var(--font-sm);
  color: var(--primary);
  font-weight: 600;
  background: var(--primary-light);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-round);
  flex-shrink: 0;
}

/* =========================================================== */
/* 5. 预览表格                                                 */
/* =========================================================== */

.preview-table {
  background: #fff;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: 20rpx;
}

.preview-header {
  display: flex;
  background: var(--gray-2);
  padding: 20rpx 16rpx;
  font-weight: 600;
  font-size: var(--font-sm);
  color: var(--gray-7);
}

.preview-row {
  display: flex;
  padding: 18rpx 16rpx;
  border-bottom: 2rpx solid var(--gray-2);
  font-size: var(--font-md);
  color: var(--gray-8);
}

.preview-row:last-child {
  border-bottom: none;
}

.preview-row.overflow {
  display: none;
}

.preview-col {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.col-sn {
  width: 60rpx;
  flex-shrink: 0;
  color: var(--gray-5);
}

.col-name {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}

.col-age {
  width: 74rpx;
  flex-shrink: 0;
  color: var(--gray-7);
  text-align: center;
}

.col-province {
  flex: 1;
  min-width: 0;
}

.col-city {
  flex: 1;
  min-width: 0;
}

.col-phone {
  flex: 1.2;
  min-width: 0;
  color: var(--blue);
}

.col-remark {
  flex: 1.5;
  min-width: 0;
  color: var(--gray-6);
  font-size: 20rpx;
}

.preview-more {
  text-align: center;
  padding: 16rpx;
  font-size: var(--font-sm);
  color: var(--gray-5);
  background: var(--gray-1);
}

/* =========================================================== */
/* 6. 导入模式选择                                             */
/* =========================================================== */

.mode-select {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.mode-label {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-8);
  margin-bottom: 16rpx;
}

.mode-options {
  display: flex;
  gap: 16rpx;
}

.mode-option {
  flex: 1;
  padding: 20rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--gray-3);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  transition: all 0.2s;
}

.mode-option:active {
  transform: scale(0.97);
}

.mode-option.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.mode-option-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-8);
}

.mode-option.active .mode-option-title {
  color: var(--primary);
}

.mode-option-desc {
  font-size: var(--font-xs);
  color: var(--gray-6);
  line-height: 1.4;
}

/* =========================================================== */
/* 7. 操作按钮                                                 */
/* =========================================================== */

.import-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.btn-back {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--gray-2);
  color: var(--gray-7);
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 500;
}

.btn-back:active {
  opacity: 0.7;
}

.btn-confirm {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.btn-confirm:active {
  opacity: 0.85;
}

/* =========================================================== */
/* 8. 完成页面                                                 */
/* =========================================================== */

.done-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0 60rpx;
  gap: 16rpx;
}

.done-icon {
  font-size: 120rpx;
  animation: popIn 0.5s ease-out;
}

@keyframes popIn {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.done-title {
  font-size: var(--font-3xl);
  font-weight: 800;
  color: var(--gray-8);
}

.done-count {
  font-size: var(--font-lg);
  color: var(--gray-6);
  background: var(--primary-light);
  padding: 8rpx 28rpx;
  border-radius: var(--radius-round);
  margin-top: 8rpx;
}

/* =========================================================== */
/* 9. 字段识别结果                                             */
/* =========================================================== */

.detected-fields {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.detected-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-7);
  display: block;
  margin-bottom: 12rpx;
}

.detected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.detected-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.detected-tag.tag-ok {
  background: #e6f9ed;
  color: #07c160;
}

.detected-tag.tag-warn {
  background: #fff3e0;
  color: #ff976a;
}

/* =========================================================== */
/* 10. 动画                                                    */
/* =========================================================== */

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-up {
  animation: slideUp 0.4s ease-out both;
}
