/* =========================================================== */
/* 关于我们 — 品牌化设计（v2）                                 */
/* =========================================================== */

.page {
  padding: 0 0 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--gray-1);
}

/* =========================================================== */
/* 1. 品牌头                                                    */
/* =========================================================== */

.app-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 56rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 40%, #059e4e 100%);
  position: relative;
  overflow: hidden;
}

.app-header::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.app-header::after {
  content: '';
  position: absolute;
  bottom: -160rpx;
  left: -80rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
}

.app-logo-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.app-name {
  font-size: var(--font-3xl);
  font-weight: 700;
  color: #fff;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
  letter-spacing: 2rpx;
}

.app-version {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 24rpx;
  border-radius: var(--radius-round);
  position: relative;
  z-index: 1;
}

/* =========================================================== */
/* 2. 卡片分区                                                  */
/* =========================================================== */

.section {
  background: #fff;
  border-radius: var(--radius-xl);
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-2);
}

.section-header {
  padding: 24rpx 28rpx 8rpx;
  border-bottom: 2rpx solid var(--gray-2);
  position: relative;
}

.section-header::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 8rpx;
  width: 6rpx;
  background: var(--primary);
  border-radius: 0 4rpx 4rpx 0;
}

.section-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--gray-8);
  padding-left: 16rpx;
}

/* =========================================================== */
/* 3. 信息展示项                                                */
/* =========================================================== */

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid var(--gray-2);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-lg);
  color: var(--gray-7);
  font-weight: 500;
}

.info-value {
  font-size: var(--font-lg);
  color: var(--gray-8);
  font-weight: 600;
}

/* =========================================================== */
/* 4. 关于内容                                                  */
/* =========================================================== */

.about-content {
  padding: 20rpx 28rpx;
}

.about-text {
  font-size: var(--font-md);
  color: var(--gray-7);
  line-height: 1.8;
}

/* =========================================================== */
/* 5. 功能列表                                                  */
/* =========================================================== */

.feature-list {
  padding: 8rpx 0;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 16rpx;
  transition: background 0.15s;
}

.feature-item:active {
  background: var(--gray-1);
}

.feature-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: var(--primary-light);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.feature-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--gray-8);
}

.feature-desc {
  font-size: 20rpx;
  color: var(--gray-5);
}

/* =========================================================== */
/* 6. 联系项                                                    */
/* =========================================================== */

.contact-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  gap: 16rpx;
  transition: background 0.15s;
}

.contact-item:active {
  background: var(--gray-1);
}

.contact-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.contact-label {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--gray-8);
}

.contact-desc {
  font-size: 20rpx;
  color: var(--gray-5);
}

.contact-arrow {
  font-size: 36rpx;
  color: var(--gray-4);
  flex-shrink: 0;
}

/* =========================================================== */
/* 7. 底部版权                                                  */
/* =========================================================== */

.footer-copyright {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.copyright-text {
  font-size: 20rpx;
  color: var(--gray-5);
}

/* =========================================================== */
/* 动画                                                        */
/* =========================================================== */

.slide-up {
  animation: slideUp 0.35s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
