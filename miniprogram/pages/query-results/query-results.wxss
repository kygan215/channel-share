/* =========================================================== */
/* 查询结果页 / 管理页共享 — 卡片样式                          */
/* =========================================================== */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* =========================================================== */
/* 1. 滚动列表区域                                             */
/* =========================================================== */

.list-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 20rpx 20rpx;
}

/* =========================================================== */
/* 2. 省份分组                                                 */
/* =========================================================== */

.group {
  margin-top: 20rpx;
}

.group-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 8rpx;
}

.group-title-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--gray-8);
}

.group-title-icon {
  font-size: var(--font-lg);
}

.group-count {
  font-size: var(--font-xs);
  color: var(--gray-5);
  background: var(--gray-2);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
}

/* =========================================================== */
/* 3. 促销员卡片                                               */
/* =========================================================== */

.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  transition: box-shadow 0.3s;
  border: 2rpx solid var(--gray-2);
}

.card:active {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* ---- 卡片头部：头像 + 姓名 + 状态 ---- */
.card-header {
  padding: 24rpx 24rpx 0;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--orange-light);
  color: var(--orange);
  font-size: var(--font-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 700;
}

.card-name-col {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
  display: block;
  line-height: 1.3;
}

.card-subtitle-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
}

.card-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
  white-space: nowrap;
}

.card-badge.badge-hired {
  background: #e6f9ed;
  color: #07c160;
  font-weight: 600;
}

.card-badge.badge-working {
  background: #e6f9ed;
  color: #07c160;
  font-weight: 600;
}

.card-badge.badge-active {
  background: #e6f9ed;
  color: #07c160;
  font-weight: 600;
}

.card-badge.badge-expire {
  background: #e8f4fd;
  color: #3b7cff;
  font-weight: 600;
}

.card-badge.badge-approved {
  background: #e6f9ed;
  color: #07c160;
  font-weight: 600;
}

.card-badge.badge-pending {
  background: #fff3e0;
  color: #ff976a;
  font-weight: 600;
}

.card-badge.badge-black {
  background: #fef0f0;
  color: #e64340;
  font-weight: 600;
}

.card-badge.badge-quality {
  background: #fff7e6;
  color: #ff6a00;
  font-weight: 600;
}

.card-badge.badge-age {
  background: #fef4e8;
  color: #c0392b;
  font-weight: 600;
}

.card-badge.badge-past {
  background: #fff3e0;
  color: #ff976a;
  font-weight: 600;
}

.card-badge.badge-none {
  background: var(--gray-3);
  color: var(--gray-5);
}

.card-city-tag {
  font-size: 22rpx;
  color: var(--gray-6);
  background: var(--gray-2);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
  white-space: nowrap;
}

.card-sn-inline {
  font-size: 20rpx;
  color: var(--gray-5);
  background: var(--gray-2);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
  flex-shrink: 0;
  white-space: nowrap;
}

/* ---- 卡片信息 ---- */
.card-body {
  padding: 20rpx 24rpx 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: var(--font-lg);
  line-height: 1.5;
}

.info-icon {
  font-size: var(--font-md);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.info-value {
  color: var(--gray-8);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.info-value.phone {
  color: var(--blue);
  font-weight: 600;
}

.info-value.location {
  color: var(--gray-7);
  font-size: var(--font-md);
}

.profile-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 12rpx 0 6rpx;
}

.profile-chip {
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 16rpx;
  background: #f5f7fa;
  color: var(--gray-7);
  border-radius: var(--radius-round);
  font-size: 20rpx;
  font-weight: 500;
}

.copy-btn {
  flex-shrink: 0;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  background: var(--blue-light);
  color: var(--blue);
  border-radius: var(--radius-round);
  font-size: 22rpx;
  margin-left: 12rpx;
  font-weight: 500;
}

.copy-btn:active {
  opacity: 0.7;
}

/* ---- 添加者信息 ---- */
.recorder-info {
  margin-top: 4rpx;
  padding: 8rpx 0;
}

.recorder-text {
  font-size: 22rpx;
  color: var(--gray-5);
}

/* ---- 备注信息 ---- */
.remark-info {
  margin-top: 4rpx;
  padding: 8rpx 0;
}

.remark-text {
  font-size: 22rpx;
  color: var(--gray-6);
  line-height: 1.5;
}

/* ---- KA 系统经验标签 ---- */
.ka-section {
  margin-top: 8rpx;
  padding: 4rpx 0;
}

.ka-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.ka-tag {
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 14rpx;
  background: var(--blue-light);
  color: var(--blue);
  border-radius: var(--radius-round);
  font-size: 18rpx;
  font-weight: 500;
  white-space: nowrap;
}

.salary-info {
  margin-top: 6rpx;
  padding: 6rpx 0;
}

.salary-text {
  font-size: 22rpx;
  color: var(--orange);
  font-weight: 500;
}

/* ---- 健康证状态 ---- */
.healthcert-section {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: var(--gray-1);
  border-radius: var(--radius-sm);
}

.healthcert-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.healthcert-label {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-7);
}

.healthcert-status {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.healthcert-status.status-none {
  background: var(--gray-3);
  color: var(--gray-5);
}

.healthcert-status.status-pending {
  background: #fff3e0;
  color: #ff976a;
}

.healthcert-status.status-approved {
  background: #e6f9ed;
  color: #07c160;
  font-weight: 600;
}

.healthcert-status.status-rejected {
  background: #fef0f0;
  color: #e64340;
}

.healthcert-reject-reason {
  font-size: 20rpx;
  color: #e64340;
  margin-top: 6rpx;
  line-height: 1.4;
}

/* ---- 聘用状态栏 ---- */
.hire-status-bar {
  margin: 0 24rpx;
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
}

.hire-status-bar.active {
  background: #e6f9ed;
}

.hire-status-bar.past {
  background: #fff7e6;
}

.hire-status-text {
  display: block;
  font-size: 22rpx;
  color: #07c160;
  font-weight: 500;
}

.hire-status-bar.past .hire-status-text {
  color: #ff6a00;
}

.hire-comment {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--gray-7);
  line-height: 1.45;
}

/* ---- 操作栏 ---- */
.card-actions {
  display: flex;
  padding: 8rpx 16rpx 16rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: var(--font-sm);
  padding: 0 16rpx;
  background: var(--gray-2);
  color: var(--gray-7);
  flex: 1;
  min-width: 0;
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.94);
}

.action-icon {
  font-size: var(--font-md);
}

.btn-hire {
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 600;
}

.btn-unhire {
  background: var(--orange-light);
  color: var(--orange);
  font-weight: 600;
}

.btn-comment-toggle {
  background: var(--gray-2);
  color: var(--gray-6);
}

.btn-comment-toggle.active {
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 600;
}

.btn-edit {
  background: var(--primary-light);
  color: var(--primary);
}

.btn-delete {
  background: var(--danger-light);
  color: var(--danger);
}

/* =========================================================== */
/* 4. 评论区域                                                 */
/* =========================================================== */

.comments-section {
  padding: 16rpx 24rpx 0;
  border-top: 2rpx solid var(--gray-2);
  margin: 0 24rpx;
}

.comments-section .comment-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.comment-item {
  display: flex;
  gap: 10rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx solid var(--gray-2);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  color: #fff;
  font-size: var(--font-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 600;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.comment-nickname {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--primary);
}

.comment-time {
  font-size: 20rpx;
  color: var(--gray-5);
  flex: 1;
}

.comment-del {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: var(--gray-2);
  color: var(--gray-5);
  border-radius: 50%;
  font-size: 22rpx;
  padding: 0;
}

.comment-content {
  font-size: var(--font-md);
  color: var(--gray-8);
  line-height: 1.5;
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.quick-tag {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 20rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-round);
  font-size: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
}

.quick-tag:active {
  background: var(--primary);
  color: #fff;
}

/* 评论输入 */
.comment-input-area {
  padding: 0 24rpx 20rpx;
}

.comment-input-row {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  height: 64rpx;
  background: #fff;
  border-radius: var(--radius-round);
  padding: 0 24rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  border: 2rpx solid var(--gray-3);
  transition: border-color 0.2s;
}

.comment-input:focus {
  border-color: var(--primary);
}

.send-btn {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(7, 193, 96, 0.3);
}

.send-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

/* =========================================================== */
/* 5. 加载 & 空状态                                           */
/* =========================================================== */

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--gray-3);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-lg);
  color: var(--gray-6);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  gap: 12rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: var(--font-2xl);
  font-weight: 600;
  color: var(--gray-7);
}

.empty-desc {
  font-size: var(--font-md);
  color: var(--gray-5);
}

/* =========================================================== */
/* 6. 骨架屏                                                   */
/* =========================================================== */

.skeleton-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 20rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, var(--gray-2) 25%, #e8e8e8 50%, var(--gray-2) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 6rpx;
}

.skeleton-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.skeleton-name {
  width: 160rpx;
  height: 36rpx;
}

.skeleton-sub {
  width: 240rpx;
  height: 24rpx;
}

.skeleton-phone {
  width: 340rpx;
  height: 32rpx;
}

.skeleton-loc {
  width: 280rpx;
  height: 28rpx;
}

.skeleton-col {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* =========================================================== */
/* 7. 动画                                                    */
/* =========================================================== */

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.35s ease-out both;
}

.slide-up {
  animation: slideUp 0.4s ease-out both;
}

.card:nth-child(1) { animation-delay: 0.02s; }
.card:nth-child(2) { animation-delay: 0.04s; }
.card:nth-child(3) { animation-delay: 0.06s; }
.card:nth-child(4) { animation-delay: 0.08s; }
.card:nth-child(5) { animation-delay: 0.10s; }
