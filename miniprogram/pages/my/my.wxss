/* =========================================================== */
/* "我的" 页面 — 品牌化设计（v2）                               */
/* =========================================================== */

.page {
  padding: 0 0 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--gray-1);
}

/* =========================================================== */
/* 1. 品牌头（更高、更有气势）                                  */
/* =========================================================== */

.brand-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 48rpx 32rpx 56rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 40%, #059e4e 100%);
  position: relative;
  overflow: hidden;
}

.brand-header::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.brand-header::after {
  content: '';
  position: absolute;
  bottom: -160rpx;
  left: -80rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
}

.brand-header-logo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx;
  position: relative;
  z-index: 1;
}

.brand-header-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 1;
  letter-spacing: 2rpx;
}

/* =========================================================== */
/* 2. 用户资料卡（居中布局，更精致）                            */
/* =========================================================== */

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx 32rpx;
  background: #fff;
  margin: -32rpx 24rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
}

.profile-avatar-wrap {
  position: relative;
  margin-top: -50rpx;
  margin-bottom: 16rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #fff;
  font-weight: 700;
  overflow: hidden;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
}

.profile-avatar-placeholder {
  background: linear-gradient(135deg, #07c160, #059e4e);
}

.profile-avatar-badge {
  position: absolute;
  bottom: 0;
  right: -4rpx;
  font-size: 18rpx;
  color: #fff;
  background: var(--primary);
  padding: 2rpx 16rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
  border: 3rpx solid #fff;
}

.profile-avatar-edit {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  opacity: 0;
  transition: opacity 0.2s;
  border: 6rpx solid #fff;
}

.profile-avatar-wrap:active .profile-avatar-edit {
  opacity: 1;
}

.profile-body {
  text-align: center;
  width: 100%;
}

.profile-name-row {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  transition: background 0.2s;
}

.profile-name-row:active {
  background: var(--gray-2);
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gray-8);
}

.profile-edit-badge {
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 14rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.profile-subtitle {
  display: block;
  font-size: 22rpx;
  color: var(--gray-5);
  margin-top: 6rpx;
}

.profile-tags {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.profile-tag {
  font-size: 22rpx;
  color: var(--gray-6);
  background: var(--gray-1);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.profile-login-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-xl);
  font-weight: 600;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
  letter-spacing: 2rpx;
}

.profile-login-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* =========================================================== */
/* 3. 功能菜单                                                  */
/* =========================================================== */

.menu-group {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 2rpx solid var(--gray-2);
  gap: 16rpx;
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--gray-1);
}

.menu-item-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.menu-item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.menu-item-label {
  font-size: var(--font-lg);
  color: var(--gray-8);
  font-weight: 600;
}

.menu-item-value {
  font-size: 20rpx;
  color: var(--gray-5);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-item-arrow {
  font-size: 36rpx;
  color: var(--gray-4);
  flex-shrink: 0;
}

/* =========================================================== */
/* 4. 创建账号表单                                              */
/* =========================================================== */

.setup-card {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.setup-header {
  margin-bottom: 36rpx;
  text-align: center;
}

.setup-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: var(--gray-1);
  padding: 4rpx;
}

.setup-title {
  display: block;
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
}

.setup-desc {
  display: block;
  font-size: var(--font-sm);
  color: var(--gray-6);
  margin-top: 6rpx;
}

.setup-avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.setup-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 4rpx dashed var(--gray-4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.setup-avatar-btn:active {
  opacity: 0.8;
  border-color: var(--primary);
}

.setup-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.setup-avatar-empty {
  font-size: 64rpx;
  background: var(--gray-2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.setup-avatar-hint {
  font-size: 22rpx;
  color: var(--gray-5);
  margin-top: 12rpx;
}

.setup-field {
  margin-bottom: 28rpx;
}

.setup-label {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--gray-7);
  margin-bottom: 10rpx;
}

.setup-input {
  width: 100%;
  height: 84rpx;
  background: var(--gray-1);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: var(--font-lg);
  color: var(--gray-8);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.setup-input:focus {
  background: #fff;
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.08);
}

.setup-picker {
  display: flex;
  align-items: center;
  height: 84rpx;
}

.setup-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.setup-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.setup-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.setup-btn-cancel {
  background: var(--gray-1);
  color: var(--gray-7);
}

.setup-btn-confirm {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.picker-ph {
  color: var(--gray-5);
  font-size: var(--font-lg);
}

/* =========================================================== */
/* 5. 弹窗                                                      */
/* =========================================================== */

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskIn 0.25s ease-out;
}

@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-card {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: modalSlide 0.3s ease-out;
}

@keyframes modalSlide {
  from { opacity: 0; transform: translateY(40rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.modal-header {
  text-align: center;
  padding: 32rpx 32rpx 16rpx;
}

.modal-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--gray-8);
}

.modal-body {
  padding: 0 32rpx 24rpx;
  text-align: center;
}

.modal-field {
  width: 100%;
  height: 88rpx;
  background: var(--gray-1);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: var(--font-lg);
  color: var(--gray-8);
  display: flex;
  align-items: center;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.modal-field:focus {
  border-color: var(--primary);
  background: #fff;
}

.modal-actions {
  display: flex;
  border-top: 2rpx solid var(--gray-2);
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: 0;
  transition: background 0.15s;
}

.modal-btn:active {
  background: var(--gray-2);
}

.modal-btn-cancel {
  color: var(--gray-6);
  border-right: 2rpx solid var(--gray-2);
}

.modal-btn-confirm {
  color: var(--primary);
  font-weight: 700;
}

.modal-btn-danger {
  color: var(--danger);
  font-weight: 700;
}

/* =========================================================== */
/* 6. 注销警告                                                  */
/* =========================================================== */

.delete-warning {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--danger);
  margin-bottom: 8rpx;
}

.delete-desc {
  display: block;
  font-size: var(--font-sm);
  color: var(--gray-6);
  line-height: 1.6;
}

/* =========================================================== */
/* 7. 退出登录 & 注销按钮                                       */
/* =========================================================== */

.logout-btn,
.delete-account-btn {
  width: calc(100% - 48rpx);
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  text-align: center;
  margin: 0 24rpx;
}

.logout-btn {
  margin-top: 40rpx;
  background: #fff;
  color: var(--gray-7);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-3);
}

.logout-btn:active {
  background: var(--danger-light);
  border-color: var(--danger);
  color: var(--danger);
}

.delete-account-btn {
  margin-top: 20rpx;
  margin-bottom: 48rpx;
  background: transparent;
  color: var(--gray-5);
  font-size: 22rpx;
  font-weight: 400;
}

.delete-account-btn:active {
  color: var(--danger);
}

/* =========================================================== */
/* 动画                                                        */
/* =========================================================== */

.slide-up {
  animation: slideUp 0.35s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
