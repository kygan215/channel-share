/* =========================================================== */
/* 查询页 — 搜索条件表单（全新卡片式设计）                      */
/* =========================================================== */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background: var(--gray-1);
}

/* =========================================================== */
/* 1. 品牌搜索区                                                */
/* =========================================================== */

.search-hero {
  position: relative;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 40%, #059e4e 100%);
  padding: 40rpx 32rpx 80rpx;
  overflow: hidden;
}

.search-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.search-hero-bg::before {
  content: '';
  position: absolute;
  top: -150rpx;
  right: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.search-hero-bg::after {
  content: '';
  position: absolute;
  bottom: -180rpx;
  left: -80rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
}

.search-hero-content {
  position: relative;
  z-index: 1;
}

.search-hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  letter-spacing: 2rpx;
}

.search-hero-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  display: block;
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
}

/* =========================================================== */
/* 2. 搜索栏（悬浮卡片）                                        */
/* =========================================================== */

.search-bar-card {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: 20rpx 24rpx;
  margin: -48rpx 20rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.12);
  position: relative;
  z-index: 2;
}

.search-row {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  padding: 0 12rpx 0 24rpx;
  gap: 10rpx;
  transition: all 0.2s;
}

.search-row:focus-within {
  background: #fff;
  box-shadow: 0 0 0 2rpx var(--primary);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: var(--font-lg);
  color: var(--gray-8);
  height: 100%;
}

.search-ph {
  color: var(--gray-5);
  font-size: 24rpx;
}

.search-clear {
  font-size: 30rpx;
  color: var(--gray-5);
  flex-shrink: 0;
  padding: 8rpx 12rpx;
}

.search-bar-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.btn-add {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.btn-add:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-icon {
  font-size: 28rpx;
}

/* =========================================================== */
/* 3. 筛选区                                                    */
/* =========================================================== */

.filter-scroll-area {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 16rpx 20rpx 40rpx;
}

.filter-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ── 筛选卡片 ── */
.filter-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 24rpx 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid var(--gray-2);
  transition: border-color 0.2s;
}

.filter-card:active {
  border-color: var(--primary-light);
}

.filter-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.filter-card-icon {
  font-size: 28rpx;
}

.filter-card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--gray-8);
  flex: 1;
}

.filter-card-selected {
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── 标签滚动 ── */
.tag-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding: 4rpx 0;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 26rpx;
  margin-right: 12rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  color: var(--gray-7);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
  font-weight: 500;
}

.filter-tag:active {
  transform: scale(0.94);
}

.filter-tag.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(7, 193, 96, 0.25);
}

/* ── 搜索输入框 ── */
.filter-search-input {
  width: 100%;
  height: 60rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--gray-8);
  box-sizing: border-box;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.filter-search-input:focus {
  background: #fff;
  border-color: var(--primary);
}

/* ── 筛选激活提示 ── */
.filter-active-tip {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: var(--gray-5);
  margin-top: 4rpx;
  padding-left: 4rpx;
}

.filter-active-value {
  color: var(--primary);
  font-weight: 500;
}

/* =========================================================== */
/* 4. 搜索按钮                                                 */
/* =========================================================== */

.search-submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 24rpx rgba(7, 193, 96, 0.35);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.search-submit-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}
