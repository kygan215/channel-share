/* =========================================================== */
/* 查询页样式 — 搜索条件表单                                   */
/* =========================================================== */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* =========================================================== */
/* 1. 顶部工具栏                                               */
/* =========================================================== */

.toolbar {
  padding: 16rpx 20rpx 12rpx;
  background: #fff;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-row {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  padding: 0 12rpx 0 20rpx;
  gap: 8rpx;
  transition: background 0.2s;
}

.search-row:focus-within {
  background: #fff;
  box-shadow: 0 0 0 2rpx var(--primary);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  padding: 8rpx 4rpx;
}

.search-input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--gray-8);
  height: 100%;
}

.search-ph {
  color: var(--gray-5);
  font-size: 22rpx;
}

.search-clear {
  font-size: 30rpx;
  color: var(--gray-5);
  flex-shrink: 0;
  padding: 8rpx 12rpx;
}

.toolbar-btns {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-add {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  display: flex;
  align-items: center;
  gap: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.btn-add:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.btn-icon {
  font-size: 28rpx;
}

/* =========================================================== */
/* 2. 筛选区域（可滚动）                                       */
/* =========================================================== */

.filter-scroll-area {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-section {
  padding: 16rpx 20rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-block {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.filter-label {
  font-size: var(--font-xs);
  color: var(--gray-6);
  flex-shrink: 0;
  width: 6em;
  padding-top: 8rpx;
}

.filter-col {
  flex: 1;
  min-width: 0;
}

.filter-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  flex: 1;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 22rpx;
  margin-right: 10rpx;
  background: var(--gray-2);
  border-radius: var(--radius-round);
  font-size: var(--font-xs);
  color: var(--gray-7);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
}

.filter-tag.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.25);
}

.filter-search-input {
  width: 100%;
  height: 56rpx;
  background: var(--gray-2);
  border-radius: var(--radius-md);
  padding: 0 18rpx;
  font-size: var(--font-xs);
  color: var(--gray-8);
  box-sizing: border-box;
  margin-bottom: 6rpx;
  border: 2rpx solid transparent;
}

.filter-search-input:focus {
  background: #fff;
  border-color: var(--primary);
}

/* =========================================================== */
/* 3. 搜索按钮                                                 */
/* =========================================================== */

.search-submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-round);
  font-size: var(--font-xl);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.35);
  margin-top: 8rpx;
}

.search-submit-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.search-submit-icon {
  font-size: 36rpx;
}
